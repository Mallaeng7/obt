{
  "name": "@obt/bot",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "lint": "eslint \"src/**/*.ts*\"",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate --schema=src/database/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=src/database/prisma/schema.prisma",
    "prisma:deploy": "prisma migrate deploy --schema=src/database/prisma/schema.prisma"
  },
  "dependencies": {
    "@discordjs/voice": "^0.17.0",
    "@liamcottle/rustplus.js": "^2.5.0",
    "@obt/rust-data": "workspace:*",
    "@obt/shared-types": "workspace:*",
    "@prisma/client": "^5.14.0",
    "discord.js": "^14.15.2",
    "dotenv": "^16.4.5",
    "fastify": "^4.26.2",
    "fastify-plugin": "^4.5.1",
    "jsonwebtoken": "^9.0.2",
    "node-edge-tts": "^1.2.10",
    "pino": "^9.1.0",
    "pino-pretty": "^11.0.0",
    "push-receiver": "^2.1.1",
    "socket.io": "^4.7.5",
    "vm2": "^3.9.19",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@obt/tsconfig": "workspace:*",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.12",
    "prisma": "^5.14.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
