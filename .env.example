# ─────────────────────────────────────────
# 🔐 필수 자격 증명
# ─────────────────────────────────────────
STEAM_API_KEY=your_steam_web_api_key
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_APPLICATION_ID=your_discord_application_id
DISCORD_GUILD_ID=your_discord_guild_id

# Rust+ FCM (Firebase Cloud Messaging)
# FCM 인증 정보는 더 이상 .env에 수동으로 입력하지 않습니다.
# 봇 실행 후 디스코드에서 /credentials add 명령어로 입력하세요.

# ─────────────────────────────────────────
# 🗄️ 데이터베이스
# ─────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/rustplusbot

# ─────────────────────────────────────────
# 🔒 보안
# ─────────────────────────────────────────
JWT_SECRET=your_jwt_secret_key_min_32_chars
ENCRYPTION_KEY=your_encryption_key_for_credentials_min_32_chars

# ─────────────────────────────────────────
# 🌐 서버 설정
# ─────────────────────────────────────────
BOT_API_PORT=3001
WEB_PORT=3000
NODE_ENV=production

# ─────────────────────────────────────────
# 🔊 TTS 음성 (선택)
# ─────────────────────────────────────────
TTS_ENABLED=true
TTS_ENGINE=edge-tts
